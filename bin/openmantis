#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
PID_FILE="$PROJECT_ROOT/.openmantis/openmantis.pid"
LOG_FILE="$PROJECT_ROOT/.openmantis/openmantis.log"

cd "$PROJECT_ROOT"

# Ensure runtime directory exists
mkdir -p .openmantis

check_bun() {
  if ! command -v bun &>/dev/null; then
    echo "Error: bun is not installed. Install it from https://bun.sh" >&2
    exit 1
  fi
}

get_pid() {
  if [[ -f "$PID_FILE" ]]; then
    cat "$PID_FILE"
  fi
}

is_running() {
  local pid
  pid="$(get_pid)"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    return 0
  fi
  return 1
}

do_start() {
  check_bun
  if is_running; then
    echo "OpenMantis is already running (PID $(get_pid))"
    exit 1
  fi

  echo "Building web assets..."
  bun run build:web

  echo "Starting OpenMantis..."
  nohup bun src/index.ts >> "$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" > "$PID_FILE"

  sleep 1
  if kill -0 "$pid" 2>/dev/null; then
    echo "OpenMantis started (PID $pid)"
  else
    rm -f "$PID_FILE"
    echo "Error: OpenMantis failed to start. Check log: $LOG_FILE" >&2
    exit 1
  fi
}

do_stop() {
  if ! is_running; then
    echo "OpenMantis is not running"
    # Clean up stale PID file
    rm -f "$PID_FILE"
    return 0
  fi

  local pid
  pid="$(get_pid)"
  echo "Stopping OpenMantis (PID $pid)..."
  if ! kill "$pid" 2>/dev/null; then
    echo "Error: could not send SIGTERM to PID $pid (permission denied?)" >&2
    rm -f "$PID_FILE"
    return 1
  fi

  local i=0
  while (( i < 5 )); do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 1
    i=$(( i + 1 ))
  done

  if kill -0 "$pid" 2>/dev/null; then
    echo "Force killing..."
    kill -9 "$pid" 2>/dev/null || true
    sleep 1
  fi

  rm -f "$PID_FILE"
  echo "OpenMantis stopped"
}

do_restart() {
  do_stop
  do_start
}

do_status() {
  if is_running; then
    echo "OpenMantis is running (PID $(get_pid))"
  else
    echo "OpenMantis is not running"
    # Clean up stale PID file
    rm -f "$PID_FILE"
  fi
}

do_log() {
  if [[ ! -f "$LOG_FILE" ]]; then
    echo "No log file found at $LOG_FILE"
    exit 1
  fi
  tail -f "$LOG_FILE"
}

usage() {
  cat <<EOF
Usage: openmantis <command>

Commands:
  start     Start OpenMantis (daemon)
  stop      Stop OpenMantis
  restart   Restart OpenMantis
  status    Show running status
  log       Tail the log file
EOF
}

case "${1:-}" in
  start)   do_start ;;
  stop)    do_stop ;;
  restart) do_restart ;;
  status)  do_status ;;
  log)     do_log ;;
  *)       usage; exit 1 ;;
esac
